// md-audit bundled markdownlint-cli2 config.
//
// Passed EXPLICITLY via `--config` so the rule set is fixed regardless of
// where the target skill lives — md-audit must never inherit an ambient
// `.markdownlint.*` from a target's host repo (markdownlint walks up the
// directory tree looking for one; an explicit --config is what prevents a
// stray config from silently changing the rules).
//
// Posture: `default: false`, then enable ONLY an explicit allowlist of
// whitespace-class, auto-fixable rules. This is deliberate — NOT `default:
// true`:
//   1. Version stability. `npx markdownlint-cli2@<pinned>` does not pin the
//      underlying markdownlint *engine* (a transitive dep), so a newer engine
//      can introduce rules `default: true` would silently switch on. An
//      explicit allowlist keeps behavior identical across engine versions:
//      rules not listed here stay off, old engine or new.
//   2. No structural rewrites. Rules that renumber/re-indent lists (MD029,
//      MD005, MD007), edit heading text (MD026), or rewrite words (MD044)
//      can change rendered meaning. They are intentionally NOT enabled — a
//      "never change meaning" tool must not run them. (A dry-run caught
//      MD029 renumbering a normative ordered list under `default: true`.)
//
// Every rule below is whitespace/punctuation-spacing only: it cannot reorder,
// renumber, reword, or restructure content.
{
  "config": {
    "default": false,

    "MD009": true, // trailing spaces (default br_spaces:2 preserves intentional hard-breaks)
    "MD010": true, // hard tabs -> spaces
    "MD012": true, // collapse multiple consecutive blank lines
    "MD018": true, // space after # in ATX heading
    "MD019": true, // multiple spaces after # in ATX heading
    "MD020": true, // space inside closed ATX heading
    "MD021": true, // multiple spaces inside closed ATX heading
    "MD022": true, // blank lines around headings (adds blanks; never edits text)
    "MD023": true, // headings start at line start
    "MD027": true, // multiple spaces after blockquote marker
    "MD030": true, // spaces after list marker (spacing only, no renumber)
    "MD031": true, // blank lines around fenced code blocks (adds blanks)
    "MD032": true, // blank lines around lists (adds blanks)
    "MD047": true, // single trailing newline at end of file

    // MD004 (bullet-marker style) is whitespace-adjacent and auto-fixable, but
    // it rewrites the marker character (* / + / -), which is a visible change.
    // Enabled, but md-audit always shows it in the formatting diff.
    "MD004": true
  },

  // Apply auto-fixes. md-audit still shows every change in the diff before
  // writing — MD004 (bullet marker) and MD047 (trailing newline) are visible
  // changes, and the user reviews them.
  "fix": true
}
